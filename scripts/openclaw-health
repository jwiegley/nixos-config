#!/usr/bin/env bash
# Usage: sudo openclaw-health [--full] [--quiet]
#
# Wrapper script for OpenClaw health checks.
# Triggers the appropriate systemd service inside the VM and displays results.

set -euo pipefail

FULL=false
QUIET=false
for arg in "$@"; do
  case "$arg" in
    --full) FULL=true ;;
    --quiet) QUIET=true ;;
    -h|--help)
      echo "Usage: openclaw-health [--full] [--quiet]"
      echo ""
      echo "Options:"
      echo "  --full    Run full round-trip functional tests (default: connectivity only)"
      echo "  --quiet   Show only PASS/FAIL summary (default: full output)"
      echo "  --help    Show this help message"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: openclaw-health [--full] [--quiet]"
      exit 1
      ;;
  esac
done

VM_NAME="openclaw"
STATE_DIR="/var/lib/openclaw"
OPENCLAW_DIR="${STATE_DIR}/.openclaw"
TRIGGER_FILE="${OPENCLAW_DIR}/run-health-check-full"

if $FULL; then
  SERVICE="openclaw-health-full"
  LOG="${OPENCLAW_DIR}/logs/health-check-full.txt"
else
  SERVICE="openclaw-health"
  LOG="${OPENCLAW_DIR}/logs/health-check.txt"
fi

# Check VM is running
if ! systemctl is-active --quiet "microvm@${VM_NAME}"; then
  echo "VM microvm@${VM_NAME} is not running. Starting..."
  systemctl start "microvm@${VM_NAME}"
  echo "Waiting for VM to boot (30 seconds)..."
  sleep 30
fi

echo "Checking OpenClaw health..."

if $FULL; then
  # For full tests, we need to trigger the service manually
  # machinectl doesn't work with QEMU microVMs, so use a file-based trigger

  # Remove stale log and trigger to avoid displaying old results
  rm -f "$LOG"
  rm -f "$TRIGGER_FILE"

  # Create trigger file as openclaw user (root-owned files get cleaned up
  # by the guest VM before chown can execute)
  sudo -u openclaw touch "$TRIGGER_FILE"

  echo "Trigger file created at $TRIGGER_FILE"
  echo "Waiting for guest to detect and run health check (up to 5 minutes)..."

  # Wait for the guest to run the check and write results (max 5 min)
  for i in {1..150}; do
    sleep 2
    if [ -f "$LOG" ] && grep -q "^=== Summary:" "$LOG" 2>/dev/null; then
      break
    fi
  done
else
  # Wait for a fresh connectivity check (not stale from a previous boot).
  # Record the current mtime; once the health-check service starts writing
  # the mtime will change, then we wait for the summary line.
  STALE_MTIME=$(stat -c %Y "$LOG" 2>/dev/null || echo "0")
  echo "Waiting for connectivity check to complete (gateway needs ~80s)..."
  for i in {1..120}; do
    CURRENT_MTIME=$(stat -c %Y "$LOG" 2>/dev/null || echo "0")
    if [ "$CURRENT_MTIME" -gt "$STALE_MTIME" ] && grep -q "^=== Summary:" "$LOG" 2>/dev/null; then
      break
    fi
    sleep 2
  done
fi

# Display results
if [ -f "$LOG" ]; then
  if $QUIET; then
    # Just show PASS/FAIL summary
    grep -E "^(PASS|FAIL|SKIP):" "$LOG" || echo "(no results found)"
    echo ""
    grep "^=== Summary:" "$LOG" || true
  else
    cat "$LOG"
  fi

  # Exit with failure if any FAIL lines exist
  if grep -q "^FAIL:" "$LOG"; then
    echo ""
    echo "ERROR: One or more health checks failed. See log for details."
    exit 1
  fi
else
  echo "FAIL: Log file not found at $LOG"
  echo ""
  if $FULL; then
    echo "The full health check service may not have run yet."
    echo "Check if the openclaw-vm guest is receiving the trigger file."
  else
    echo "The boot-time health check should have run automatically."
    echo "Try: sudo systemctl restart microvm@openclaw"
  fi
  exit 1
fi
