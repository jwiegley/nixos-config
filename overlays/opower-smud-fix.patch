+class SMUDAccountSelectionParser(HTMLParser):
+    """HTML parser to extract account numbers from the SMUD account selection page."""
+
+    def __init__(self) -> None:
+        """Initialize."""
+        super().__init__()
+        self.account_numbers: list[str] = []
+        self.verification_token: str | None = None
+
+    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
+        """Extract account numbers and verification token."""
+        attrs_dict = dict(attrs)
+        if tag == "div" and "data-account-number" in attrs_dict:
+            acct = attrs_dict["data-account-number"]
+            if acct and acct not in self.account_numbers:
+                self.account_numbers.append(acct)
+        if tag == "input" and ("name", "__RequestVerificationToken") in attrs:
+            _, token = next(filter(lambda attr: attr[0] == "value", attrs))
+            if token is not None:
+                self.verification_token = token
+
